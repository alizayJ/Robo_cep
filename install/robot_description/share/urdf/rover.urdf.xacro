<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="my_robot">

  <!-- ================= PARAMETERS ================= -->
  <xacro:property name="pi" value="3.14159265359"/>

  <!-- Base dimensions -->
  <xacro:property name="base_length" value="0.6"/>
  <xacro:property name="base_width"  value="0.4"/>
  <xacro:property name="base_height" value="0.2"/>
  <xacro:property name="base_mass"   value="8.0"/>

  <!-- Wheel -->
  <xacro:property name="wheel_radius" value="0.1"/>
  <xacro:property name="wheel_width"  value="0.05"/>
  <xacro:property name="wheel_mass"   value="1.0"/>

  <!-- Lidar -->
  <xacro:property name="lidar_radius" value="0.1"/>
  <xacro:property name="lidar_length" value="0.05"/>
  <xacro:property name="lidar_mass"   value="0.5"/>

  <!-- Caster -->
  <xacro:property name="caster_radius" value="0.05"/>
  <xacro:property name="caster_mass"   value="0.3"/>

  <!-- ================= MATERIALS ================= -->
  <material name="green">
    <color rgba="0 0.6 0 1"/>
  </material>

  <material name="white">
    <color rgba="1 1 1 1"/>
  </material>

  <material name="red">
    <color rgba="0.7 0 0 1"/>
  </material>

  <!-- ================= BASE FOOTPRINT ================= -->
  <link name="base_footprint"/>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
  </joint>

  <!-- ================= BASE LINK ================= -->
  <link name="base_link">

    <visual>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
      <material name="green"/>
    </visual>

    <collision>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
    </collision>

    <inertial>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
      <mass value="${base_mass}"/>

      <!-- Box inertia -->
      <inertia
        ixx="${(1.0/12.0)*base_mass*(base_width*base_width + base_height*base_height)}"
        ixy="0"
        ixz="0"
        iyy="${(1.0/12.0)*base_mass*(base_length*base_length + base_height*base_height)}"
        iyz="0"
        izz="${(1.0/12.0)*base_mass*(base_length*base_length + base_width*base_width)}"/>
    </inertial>

  </link>

  <!-- ================= LIDAR ================= -->
  <link name="lidar">

    <visual>
      <geometry>
        <cylinder radius="${lidar_radius}" length="${lidar_length}"/>
      </geometry>
      <material name="white"/>
    </visual>

    <collision>
      <geometry>
        <cylinder radius="${lidar_radius}" length="${lidar_length}"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="${lidar_mass}"/>
      <inertia
        ixx="${(1.0/12.0)*lidar_mass*(3*lidar_radius*lidar_radius + lidar_length*lidar_length)}"
        ixy="0"
        ixz="0"
        iyy="${(1.0/12.0)*lidar_mass*(3*lidar_radius*lidar_radius + lidar_length*lidar_length)}"
        iyz="0"
        izz="${0.5*lidar_mass*lidar_radius*lidar_radius}"/>
    </inertial>

  </link>

  <joint name="base_lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar"/>
    <origin xyz="0 0 0.225" rpy="0 0 0"/>
  </joint>

  <!-- ================= LEFT WHEEL ================= -->
  <link name="left_wheel">

    <visual>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <origin xyz="0 0 0" rpy="1.57 0 0"/>
      <material name="red"/>
    </visual>

    <collision>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <origin xyz="0 0 0" rpy="1.57 0 0"/>
    </collision>

    <inertial>
      <mass value="${wheel_mass}"/>
      <inertia
        ixx="${(1.0/12.0)*wheel_mass*(3*wheel_radius*wheel_radius + wheel_width*wheel_width)}"
        ixy="0"
        ixz="0"
        iyy="${0.5*wheel_mass*wheel_radius*wheel_radius}"
        iyz="0"
        izz="${(1.0/12.0)*wheel_mass*(3*wheel_radius*wheel_radius + wheel_width*wheel_width)}"/>
    </inertial>

  </link>

  <joint name="base_left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="-0.15 0.225 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- ================= RIGHT WHEEL ================= -->
  <link name="right_wheel">

    <visual>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <origin xyz="0 0 0" rpy="1.57 0 0"/>
      <material name="red"/>
    </visual>

    <collision>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <origin xyz="0 0 0" rpy="1.57 0 0"/>
    </collision>

    <inertial>
      <mass value="${wheel_mass}"/>
      <inertia
        ixx="${(1.0/12.0)*wheel_mass*(3*wheel_radius*wheel_radius + wheel_width*wheel_width)}"
        ixy="0"
        ixz="0"
        iyy="${0.5*wheel_mass*wheel_radius*wheel_radius}"
        iyz="0"
        izz="${(1.0/12.0)*wheel_mass*(3*wheel_radius*wheel_radius + wheel_width*wheel_width)}"/>
    </inertial>

  </link>

  <joint name="base_right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="-0.15 -0.225 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- ================= CASTER ================= -->
  <link name="caster_wheel">

    <visual>
      <geometry>
        <sphere radius="${caster_radius}"/>
      </geometry>
      <material name="red"/>
    </visual>

    <collision>
      <geometry>
        <sphere radius="${caster_radius}"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="${caster_mass}"/>
      <inertia
        ixx="${0.4*caster_mass*caster_radius*caster_radius}"
        ixy="0"
        ixz="0"
        iyy="${0.4*caster_mass*caster_radius*caster_radius}"
        iyz="0"
        izz="${0.4*caster_mass*caster_radius*caster_radius}"/>
    </inertial>

  </link>

  <joint name="base_caster_wheel_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_wheel"/>
    <origin xyz="0.2 0 -0.05" rpy="0 0 0"/>
  </joint>

  <!-- ================= GAZEBO COLORS ================= -->
  <gazebo reference="base_link">
    <material>Gazebo/Green</material>
  </gazebo>

  <gazebo reference="left_wheel">
    <material>Gazebo/Red</material>
  </gazebo>

  <gazebo reference="right_wheel">
    <material>Gazebo/Red</material>
  </gazebo>

  <gazebo reference="caster_wheel">
    <material>Gazebo/Red</material>
  </gazebo>

  <!-- ================= DIFF DRIVE PLUGIN ================= -->
  <gazebo>
    <plugin name="diff_drive_controller" filename="libgazebo_ros_diff_drive.so">

      <ros>
        <namespace>/</namespace>
      </ros>

      <leftJoint>base_left_wheel_joint</leftJoint>
      <rightJoint>base_right_wheel_joint</rightJoint>

      <wheelSeparation>0.45</wheelSeparation>
      <wheelDiameter>0.20</wheelDiameter>

      <publishWheelTF>true</publishWheelTF>
      <publishOdom>true</publishOdom>
      <publishWheelJointState>true</publishWheelJointState>

      <odometryFrame>odom</odometryFrame>
      <robotBaseFrame>base_footprint</robotBaseFrame>

      <commandTopic>cmd_vel</commandTopic>
      <odometryTopic>odom</odometryTopic>

      <updateRate>50</updateRate>

    </plugin>
  </gazebo>

</robot>